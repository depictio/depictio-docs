# Generate a gitignore for a mkdocs project
# Python
__pycache__/
*.py[cod]
*$py.class


# MkDocs
site/
docs/site/

# Generated on the fly in CI (catalog gallery, see deploy-docs.yaml) — never committed
docs/assets/component-catalog-light.html
docs/assets/component-catalog-dark.html

# Editor/IDE
.vscode/
.idea/

# Build files
build/
dist/

# Dependency directories
.venv/
venv/
env/
uv.lock

# MacOS
.DS_Store
docs/.DS_Store
node_modules/
docs/images/.DS_Store
.DS_Store
src/
